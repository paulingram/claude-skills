{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) \"${CLAUDE_PLUGIN_ROOT}/hooks/pretool_skill_gate.py\"",
            "async": false
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) \"${CLAUDE_PLUGIN_ROOT}/hooks/pretool_unilateral_override_guard.py\"",
            "async": false
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) \"${CLAUDE_PLUGIN_ROOT}/hooks/pretool_unilateral_override_guard.py\"",
            "async": false
          }
        ]
      },
      {
        "matcher": "NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) \"${CLAUDE_PLUGIN_ROOT}/hooks/pretool_unilateral_override_guard.py\"",
            "async": false
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) \"${CLAUDE_PLUGIN_ROOT}/hooks/review-gate-task.py\"",
            "async": false
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) \"${CLAUDE_PLUGIN_ROOT}/hooks/pretool_skill_gate.py\"",
            "async": false
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) \"${CLAUDE_PLUGIN_ROOT}/hooks/review-gate-task.py\"",
            "async": false
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) \"${CLAUDE_PLUGIN_ROOT}/hooks/teammate-idle-check.py\"",
            "async": false
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) \"${CLAUDE_PLUGIN_ROOT}/hooks/teammate-idle-check.py\"",
            "async": false
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) \"${CLAUDE_PLUGIN_ROOT}/hooks/pipeline-completion-audit.py\"",
            "async": false
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) \"${CLAUDE_PLUGIN_ROOT}/hooks/precompact-closeout.py\"",
            "async": false
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) \"${CLAUDE_PLUGIN_ROOT}/hooks/sessionstart-run-continuity.py\"",
            "async": false
          }
        ]
      }
    ]
  }
}
