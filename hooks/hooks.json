{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/review-gate-task.py\" || python \"${CLAUDE_PLUGIN_ROOT}/hooks/review-gate-task.py\"",
            "async": false
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/teammate-idle-check.py\" || python \"${CLAUDE_PLUGIN_ROOT}/hooks/teammate-idle-check.py\"",
            "async": false
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/pipeline-completion-audit.py\" || python \"${CLAUDE_PLUGIN_ROOT}/hooks/pipeline-completion-audit.py\"",
            "async": false
          }
        ]
      }
    ]
  }
}
