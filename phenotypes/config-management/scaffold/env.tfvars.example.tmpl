# {{service_name}} {{env}} — copy to {{env}}.tfvars and fill. NEVER commit real account ids / secrets.
# This is the per-service FLAG PROFILE: a backend enables DB + cache; a frontend disables both.
project       = "{{project_name}}"
service       = "{{service_name}}"
env           = "{{env}}"
aws_region    = "{{aws_region}}"
image         = "REPLACE-ACCOUNT.dkr.ecr.{{aws_region}}.amazonaws.com/{{project_name}}-{{service_name}}:latest"
desired_count = 1

# Flag profile (three-state: enable_* to create, existing_*_arn to reuse, neither to disable):
enable_database = true
enable_cache    = true
