# {{service_name}} service root ({{env}}) — a THIN `module "this"` call into the standard service
# module, reading the platform layer via remote state. Apply after platform (and the load-balancer
# layer on AWS). Flip the enable_* flags per service in {{env}}.tfvars.

terraform {
  required_version = ">= 1.7"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

variable "project" {
  type = string
}
variable "service" {
  type = string
}
variable "env" {
  type = string
}
variable "aws_region" {
  type = string
}
variable "image" {
  type = string
}
variable "desired_count" {
  type    = number
  default = 1
}
variable "enable_database" {
  type    = bool
  default = true
}
variable "enable_cache" {
  type    = bool
  default = true
}

data "terraform_remote_state" "platform" {
  backend = "s3"
  config = {
    bucket = "REPLACE-${var.project}-tofu-state"
    key    = "${var.project}/platform/${var.env}/terraform.tfstate"
    region = "{{state_region}}"
  }
}

module "this" {
  source = "../../../../modules/microservice"

  project         = var.project
  service         = var.service
  env             = var.env
  cluster_arn     = data.terraform_remote_state.platform.outputs.cluster_arn
  subnet_ids      = data.terraform_remote_state.platform.outputs.private_subnet_ids
  image           = var.image
  desired_count   = var.desired_count
  enable_database = var.enable_database
  enable_cache    = var.enable_cache
  enable_secrets  = true
}
