// Index page = the codebase selector. Absorbed from deepwiki-open's src/components/ProcessedProjects.tsx
// pattern (card grid + client-side search filter), generalized: it lists the codebases.json registry
// (read server-side via lib/maps-loader) instead of an LLM-generated projects API, and the card opens
// a wiki rather than triggering generation. The search filter is a client leaf (CodebaseSearch).

import React from "react";
import { listCodebases } from "../lib/maps-loader";
import CodebaseSearch from "./CodebaseSearch";
import ThemeToggle from "../components/ThemeToggle";

// Always read the filesystem fresh (content is a mounted volume, not a build artifact).
export const dynamic = "force-dynamic";

export default async function HomePage() {
  const codebases = await listCodebases();

  return (
    <main className="page-shell surface-texture">
      <div className="page-header">
        <div>
          <h1 className="page-title">{`{{wiki_name}}`}</h1>
          <p className="page-subtitle">
            {codebases.length === 1
              ? "1 codebase"
              : `${codebases.length} codebases`}{" "}
            documented
          </p>
        </div>
        <ThemeToggle />
      </div>

      {codebases.length === 0 ? (
        <div className="empty-state">
          <p>No codebases registered yet.</p>
          <p>
            Add entries to <code className="md-inline-code">codebases.json</code> in your content
            directory: an array of <code className="md-inline-code">{`{ name, maps_dir }`}</code>{" "}
            objects, where <code className="md-inline-code">maps_dir</code> contains{" "}
            <code className="md-inline-code">*_MAP.md</code> files.
          </p>
        </div>
      ) : (
        <CodebaseSearch codebases={codebases} />
      )}
    </main>
  );
}
