# Generalized from deepwiki-open's single-image Dockerfile: kept the multi-stage node build feeding
# Next.js `output: 'standalone'`; DROPPED the python:3.11-slim stage, the Node-on-python-slim hack,
# the git install, the tiktoken pre-warm, the dual-process start.sh, and `wait -n` (no second process
# now that the Python backend is stripped). Final image runs only `node server.js`.

# ---- deps ----
FROM node:20-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json* ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

# ---- build ----
FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# ---- runner ----
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT={{port}}
ENV HOSTNAME=0.0.0.0
# WIKI_CONTENT_DIR points at the mounted content volume (see docker-compose.yml).
ENV WIKI_CONTENT_DIR=/app/content

RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs

# Next.js standalone output: server.js + a trimmed node_modules + static assets.
COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs
EXPOSE {{port}}
CMD ["node", "server.js"]
