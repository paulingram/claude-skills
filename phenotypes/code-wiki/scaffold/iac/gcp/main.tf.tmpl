# {{wiki_name}} -- GCP service-layer plug-in for the config-management phenotype.
#
# Service layer only (the ai-management precedent: components.deploy.via = "config-management
# phenotype"). Deploys the containerized wiki as a Cloud Run service into a project that the
# config-management phenotype provisions, read here via terraform_remote_state (config-management's
# GCP state backend is gcs). Contract surface matches config-management: project / service / env /
# image / enable_* ; naming ${project}-${service}-${env}.
#
# The Cloud Run service is defined inline (rather than a relative `module "this"` source) so this
# layer is self-contained and `tofu validate`-able on its own; to apply, point the remote_state
# backend at the config-management platform state.
#
# APPLY ORDER: emit + apply config-management (platform) FIRST, then apply this.

terraform {
  required_version = ">= 1.7"
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 5.0"
    }
  }
}

provider "google" {
  project = var.gcp_project
  region  = var.gcp_region
}

locals {
  name = "${var.project}-${var.service}-${var.env}"
}

# Read the platform layer provisioned by the config-management phenotype.
data "terraform_remote_state" "platform" {
  backend = "gcs"
  config = {
    bucket = var.platform_state_bucket
    prefix = "${var.project}/platform/${var.env}"
  }
}

resource "google_cloud_run_v2_service" "this" {
  name     = local.name
  location = var.gcp_region

  template {
    containers {
      image = var.image
      ports {
        container_port = var.container_port
      }
      env {
        name  = "PORT"
        value = tostring(var.container_port)
      }
      env {
        name  = "WIKI_CONTENT_DIR"
        value = var.wiki_content_dir
      }
      resources {
        limits = {
          cpu    = var.cpu_limit
          memory = var.memory_limit
        }
      }
    }
    scaling {
      min_instance_count = var.min_instances
      max_instance_count = var.max_instances
    }
  }

  labels = {
    project = var.project
    service = var.service
    env     = var.env
  }
}

output "service_name" {
  value = google_cloud_run_v2_service.this.name
}
output "service_uri" {
  value = google_cloud_run_v2_service.this.uri
}
