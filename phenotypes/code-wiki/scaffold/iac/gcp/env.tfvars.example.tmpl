# {{wiki_name}} GCP service vars -- copy to <env>.tfvars and fill. NEVER commit real project secrets.
project               = "{{project_name}}"
service               = "code-wiki"
env                   = "dev"
gcp_project           = "{{gcp_project}}"
gcp_region            = "{{gcp_region}}"
platform_state_bucket = "REPLACE-{{project_name}}-tofu-state"
image                 = "REPLACE-REGISTRY/{{project_name}}-code-wiki:latest"
container_port        = {{port}}
