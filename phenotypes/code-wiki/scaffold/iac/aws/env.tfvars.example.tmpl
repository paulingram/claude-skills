# {{wiki_name}} AWS service vars -- copy to <env>.tfvars and fill. NEVER commit real account ids.
project               = "{{project_name}}"
service               = "code-wiki"
env                   = "dev"
aws_region            = "{{aws_region}}"
state_region          = "{{aws_region}}"
platform_state_bucket = "REPLACE-{{project_name}}-tofu-state"
image                 = "REPLACE-REGISTRY/{{project_name}}-code-wiki:latest"
container_port        = {{port}}
desired_count         = 1
