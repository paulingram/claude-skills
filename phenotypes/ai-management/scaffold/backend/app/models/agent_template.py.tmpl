"""AgentTemplate + TemplateVersion + Agent models ({{service_name}}).

The prompt-versioning layer: a template carries a ``delta_config`` (holding the system_prompt + model
+ params + guardrails) at a scope in the inheritance chain; each update bumps ``version`` and writes an
immutable ``TemplateVersion`` snapshot; ``resolved_config`` is materialized from the chain.
"""
import enum
import uuid
from datetime import datetime

from sqlalchemy import DateTime, ForeignKey, Integer, String, func
from sqlalchemy.dialects.postgresql import JSONB, UUID
from sqlalchemy.orm import DeclarativeBase, Mapped, mapped_column


class Base(DeclarativeBase):
    pass


class Scope(str, enum.Enum):
    master = "master"
    domain = "domain"
    application = "application"
    tenant = "tenant"


class Status(str, enum.Enum):
    draft = "draft"
    active = "active"
    archived = "archived"


class AgentTemplate(Base):
    __tablename__ = "agent_templates"
    id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), primary_key=True, default=uuid.uuid4)
    tenant_id: Mapped[uuid.UUID | None] = mapped_column(UUID(as_uuid=True), index=True, nullable=True)
    scope: Mapped[str] = mapped_column(String(32))                 # Scope
    parent_id: Mapped[uuid.UUID | None] = mapped_column(ForeignKey("agent_templates.id"), nullable=True)
    inheritance_mode: Mapped[str] = mapped_column(String(16), default="floating")  # floating | locked
    pinned_parent_version: Mapped[int | None] = mapped_column(Integer, nullable=True)
    delta_config: Mapped[dict] = mapped_column(JSONB, default=dict)       # holds system_prompt, model, params...
    resolved_config: Mapped[dict] = mapped_column(JSONB, default=dict)    # materialized; runtime reads this
    version: Mapped[int] = mapped_column(Integer, default=1)
    status: Mapped[str] = mapped_column(String(16), default="draft")     # Status
    updated_at: Mapped[datetime] = mapped_column(DateTime(timezone=True), server_default=func.now(), onupdate=func.now())


class TemplateVersion(Base):
    """Append-only immutable snapshot — written on every template update; enables diff + rollback."""
    __tablename__ = "template_versions"
    id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), primary_key=True, default=uuid.uuid4)
    template_id: Mapped[uuid.UUID] = mapped_column(ForeignKey("agent_templates.id"), index=True)
    version: Mapped[int] = mapped_column(Integer)
    delta_config: Mapped[dict] = mapped_column(JSONB)
    created_at: Mapped[datetime] = mapped_column(DateTime(timezone=True), server_default=func.now())


class Agent(Base):
    __tablename__ = "agents"
    id: Mapped[uuid.UUID] = mapped_column(UUID(as_uuid=True), primary_key=True, default=uuid.uuid4)
    tenant_id: Mapped[uuid.UUID | None] = mapped_column(UUID(as_uuid=True), index=True, nullable=True)
    name: Mapped[str] = mapped_column(String(200))
    template_id: Mapped[uuid.UUID] = mapped_column(ForeignKey("agent_templates.id"))
    template_version_pinned: Mapped[int | None] = mapped_column(Integer, nullable=True)
    graph_type: Mapped[str] = mapped_column(String(64), default="conversational")  # -> GRAPH_REGISTRY
