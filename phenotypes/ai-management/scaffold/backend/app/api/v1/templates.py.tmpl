``services/template_resolver.resolve_config`` (and propagated to descendants). ``diff_config`` (same
module) powers the VersionHistory UI's server-computed field diffs.
"""
from fastapi import APIRouter
from pydantic import BaseModel

from app.services.template_resolver import resolve_config  # + diff_config for the versions diff view

router = APIRouter(prefix="/templates", tags=["templates"])


class TemplatePatch(BaseModel):
    delta_config: dict
    status: str | None = None          # "draft" | "active"


